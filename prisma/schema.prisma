// prisma/schema.prisma
// APP Précommande FOREVER — version révisée
// Cible: React + Express + Postgres + Prisma
// Inclut:
// - moteur de paiement multi-provider
// - répartition/assignation des précommandes aux facturiers
// - workflow commande modernisé

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
//

enum OrderMessageChannel {
  WHATSAPP
}

enum OrderMessagePurpose {
  INVOICE
  PAYMENT_LINK
  REMINDER
  PAYMENT_CONFIRMED
  PREPARATION_STARTED
  ORDER_READY
}

enum OrderMessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum Grade {
  ANIMATEUR_ADJOINT
  ANIMATEUR
  MANAGER_ADJOINT
  MANAGER
  CLIENT_PRIVILEGIE
}

enum DeliveryMode {
  RETRAIT_SITE_FLP
  LIVRAISON
}

enum PaymentProvider {
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  MOOV_MONEY
  MANUAL
}

enum PaymentMethodType {
  MOBILE_MONEY
  CASH
  BANK_TRANSFER
  CARD
  MANUAL_PROOF
}

enum PreorderPaymentMode {
  ESPECES
  WAVE
  ORANGE_MONEY
}

enum PaymentStatus {
  INITIATED
  PENDING_CUSTOMER_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentAttemptStatus {
  CREATED
  PROVIDER_SESSION_CREATED
  REDIRECT_READY
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAYMENT_PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum ProviderAccountStatus {
  ACTIVE
  INACTIVE
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum PaymentTransactionEventType {
  PAYMENT_INITIATED
  PROVIDER_SESSION_CREATED
  CHECKOUT_LINK_READY
  STATUS_SYNCED
  WEBHOOK_RECEIVED
  WEBHOOK_INVALID_SIGNATURE
  WEBHOOK_PROCESSED
  WEBHOOK_PREORDER_UNRESOLVED
  TRANSACTION_CAPTURED
  PAYER_PHONE_CAPTURED
  PAYMENT_CONFIRMED
  PAYMENT_EXPIRED
  PAYMENT_CANCELLED
  PAYMENT_FAILED
  DETAILS_ENRICHED
  SIMULATION_TRIGGERED
  SIMULATION_RESULT_APPLIED
}

enum PaymentTransactionSource {
  INITIATE
  SYNC
  WEBHOOK
  SIMULATION
  ENRICHMENT
  SYSTEM
}

enum PreorderStatus {
  DRAFT
  SUBMITTED
  INVOICED
  PAYMENT_PENDING
  PAID
  READY
  FULFILLED
  CANCELLED
}

enum BillingWorkStatus {
  NONE
  QUEUED
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER_DATA
  WAITING_PAYMENT
  COMPLETED
  RELEASED
  ESCALATED
}

enum BillingPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProductCategory {
  NON_CLASSE
  BUVABLE
  COMBO_PACKS
  GESTION_DE_POIDS
  NUTRITION
  PRODUIT_DE_LA_RUCHE
  SOINS_DE_LA_PEAU
  SOINS_PERSONNELS
}

enum AdminRole {
  SUPER_ADMIN
  TECH_ADMIN
  OPERATIONS_DIRECTOR
  SALES_DIRECTOR
  BILLING_MANAGER
  MARKETING_ASSISTANT
  STOCK_MANAGER
  COUNTER_MANAGER
  CAISSIERE
  INVOICER
  ORDER_PREPARER
}

enum PreorderLogAction {
  CREATE_DRAFT
  SET_ITEMS
  REPRICE
  SUBMIT

  ENQUEUE_BILLING
  ASSIGN_INVOICER
  RELEASE_INVOICER
  START_BILLING
  ESCALATE_BILLING
  WAIT_CUSTOMER_DATA

  INVOICE
  GENERATE_PAYMENT
  PAYMENT_PENDING
  RECEIVE_MANUAL_PAYMENT_PROOF
  VALIDATE_MANUAL_PAYMENT
  PAYMENT_CONFIRMED

  LAUNCH_PREPARATION
  PREPARE
  FULFILL
  CANCEL

  STOCK_DEBIT
  STOCK_CREDIT
}

enum StockMovementType {
  DEBIT
  CREDIT
}

enum StockMovementReason {
  PREPARE_ORDER
  CANCEL_ORDER
  MANUAL_ADJUSTMENT
}

//
// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------
//

model OrderMessage {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  channel OrderMessageChannel @default(WHATSAPP)
  purpose OrderMessagePurpose
  status  OrderMessageStatus  @default(DRAFT)

  toPhone String?
  body    String? @db.Text

  provider          String?
  providerMessageId String? @unique

  paymentLinkTracked String? @db.Text
  paymentLinkTarget  String? @db.Text

  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  lastStatusAt DateTime?

  errorCode    String?
  errorMessage String? @db.Text

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events OrderMessageEvent[]

  @@index([preorderId, createdAt])
  @@index([status])
  @@index([provider, providerMessageId])
}

model OrderMessageEvent {
  id String @id @default(cuid())

  orderMessageId String
  orderMessage   OrderMessage @relation(fields: [orderMessageId], references: [id], onDelete: Cascade)

  status     String
  rawPayload Json?
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([orderMessageId, createdAt])
}

model Fbo {
  id           String @id @default(cuid())
  numeroFbo    String @unique
  nomComplet   String
  grade        Grade
  pointDeVente String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorders    Preorder[]
  fboCountries FboCountry[]

  @@index([pointDeVente])
  @@index([grade])
}

model Country {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  currencyCode String?
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings                CountrySettings?
  products                Product[]
  preorders               Preorder[]
  gradeDiscounts          GradeDiscount[]
  adminUsers              AdminUser[]
  fboCountries            FboCountry[]
  payments                Payment[]
  paymentProviderAccounts PaymentProviderAccount[]
  paymentProviderRules    PaymentProviderRule[]
}

model CountrySettings {
  id        String  @id @default(cuid())
  countryId String  @unique
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  minCartFcfa Int @default(0)

  // Paramètres opérationnels facturation
  maxActiveBillingPerInvoicer Int @default(5)
  billingClaimTimeoutMin      Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  fullName String?
  role     AdminRole
  actif    Boolean   @default(true)

  countryId String?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  // Précommandes / workflow
  assignedBillingPreorders        Preorder[] @relation("PreorderAssignedInvoicer")
  invoicedPreorders               Preorder[] @relation("PreorderInvoicedBy")
  manualPaymentValidatedPreorders Preorder[] @relation("PreorderManualPaymentValidatedBy")
  launchedPreparationPreorders    Preorder[] @relation("PreorderPreparationLaunchedBy")
  preparedPreorders               Preorder[] @relation("PreorderPreparedBy")
  fulfilledPreorders              Preorder[] @relation("PreorderFulfilledBy")
  cancelledPreorders              Preorder[] @relation("PreorderCancelledBy")

  stockMovements StockMovement[]
  preorderLogs   PreorderLog[]
  paymentTransactionLogs PaymentTransactionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([role])
}

model FboCountry {
  id String @id @default(cuid())

  fboId String
  fbo   Fbo    @relation(fields: [fboId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  pointDeVente String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([fboId, countryId])
  @@index([countryId])
}

model Product {
  id       String  @id @default(cuid())
  sku      String  @unique
  nom      String
  imageUrl String?

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  category ProductCategory @default(NON_CLASSE)
  details  String?         @db.Text
  stockQty Int             @default(0)

  prixBaseFcfa Int
  cc           Decimal @db.Decimal(10, 3)
  poidsKg      Decimal @db.Decimal(10, 3)

  actif Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorderItems  PreorderItem[]
  stockMovements StockMovement[]

  @@index([actif])
  @@index([nom])
  @@index([category])
  @@index([countryId])
}

model GradeDiscount {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  grade Grade

  discountPercent Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, grade])
  @@index([countryId])
}

model Preorder {
  id String @id @default(cuid())

  // Numéro de precommande 
  preorderNumber  String? @unique
  preorderSeq     Int?
  preorderDateKey String?

  // mode de paiement
  preorderPaymentMode PreorderPaymentMode?

  // Workflow global commande
  status        PreorderStatus     @default(DRAFT)
  paymentStatus OrderPaymentStatus @default(UNPAID)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  fboId String
  fbo   Fbo    @relation(fields: [fboId], references: [id], onDelete: Restrict)

  // Snapshot FBO
  fboNumero     String
  fboNomComplet String
  fboGrade      Grade
  pointDeVente  String

  // Livraison
  deliveryMode DeliveryMode?

  // Totaux
  totalCc            Decimal @default(0.000) @db.Decimal(12, 3)
  totalPoidsKg       Decimal @default(0.000) @db.Decimal(12, 3)
  totalProduitsFcfa  Int     @default(0)
  fraisLivraisonFcfa Int     @default(0)
  totalFcfa          Int     @default(0)

  // File / répartition facturiers
  billingWorkStatus     BillingWorkStatus @default(NONE)
  billingPriority       BillingPriority   @default(NORMAL)
  billingQueueEnteredAt DateTime?
  assignedAt            DateTime?
  billingStartedAt      DateTime?
  billingLastActivityAt DateTime?
  billingCompletedAt    DateTime?
  billingReleasedAt     DateTime?
  billingEscalatedAt    DateTime?
  billingSlaDeadlineAt  DateTime?

  assignedInvoicerId String?
  assignedInvoicer   AdminUser? @relation("PreorderAssignedInvoicer", fields: [assignedInvoicerId], references: [id], onDelete: SetNull)

  // Facturation
  factureReference  String?
  factureWhatsappTo String?
  invoicedAt        DateTime?
  invoicedById      String?
  invoicedByAdmin   AdminUser? @relation("PreorderInvoicedBy", fields: [invoicedById], references: [id], onDelete: SetNull)

  // Paiement manuel (cas spécifique)
  manualPaymentReference     String?
  manualPaymentProofUrl      String?
  manualPaymentProofNote     String?    @db.Text
  manualPaymentReceivedAt    DateTime?
  manualPaymentValidatedAt   DateTime?
  manualPaymentValidatedById String?
  manualPaymentValidatedBy   AdminUser? @relation("PreorderManualPaymentValidatedBy", fields: [manualPaymentValidatedById], references: [id], onDelete: SetNull)

  // Paiement global
  paymentProvider PaymentProvider?
  paidAt          DateTime?

  // Paiement actif (facilite les écrans)
  activePaymentId String?
  activePayment   Payment? @relation("ActivePayment", fields: [activePaymentId], references: [id], onDelete: SetNull)

  // Préparation / fulfillment
  preparationLaunchedAt DateTime?
  preparedAt  DateTime?
  fulfilledAt DateTime?
  cancelledAt DateTime?

  preparationLaunchedById String?
  preparedById  String?
  fulfilledById String?
  cancelledById String?

  preparationLaunchedBy AdminUser? @relation("PreorderPreparationLaunchedBy", fields: [preparationLaunchedById], references: [id], onDelete: SetNull)
  preparedByAdmin  AdminUser? @relation("PreorderPreparedBy", fields: [preparedById], references: [id], onDelete: SetNull)
  fulfilledByAdmin AdminUser? @relation("PreorderFulfilledBy", fields: [fulfilledById], references: [id], onDelete: SetNull)
  cancelledByAdmin AdminUser? @relation("PreorderCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  // Divers
  whatsappMessage       String?   @db.Text
  lastWhatsappMessageId String?
  lastWhatsappStatus    String?
  lastWhatsappStatusAt  DateTime?

  paymentLinkClickedAt  DateTime?
  paymentLinkClickCount Int       @default(0)

  internalNote String? @db.Text

  deliveryTracking String?
  packingNote      String? @db.Text
  pickupSecretCode String?
  cancelReason     String? @db.Text

  stockDeductedAt DateTime?
  stockRestoredAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  items          PreorderItem[]
  logs           PreorderLog[]
  messages       OrderMessage[]
  payments       Payment[]       @relation("PreorderPayments")
  paymentTransactionLogs PaymentTransactionLog[]
  stockMovements StockMovement[]

  @@index([status, createdAt])
  @@index([preorderPaymentMode])
  @@index([countryId, status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([fboId])
  @@index([pointDeVente])
  @@index([billingWorkStatus, billingPriority, billingQueueEnteredAt])
  @@index([assignedInvoicerId, billingWorkStatus])
  @@index([billingSlaDeadlineAt])
  @@index([invoicedById])
  @@index([manualPaymentValidatedById])
  @@index([preparationLaunchedById])
  @@index([preparationLaunchedAt])
  @@index([preparedById])
  @@index([fulfilledById])
  @@index([cancelledById])
  @@index([factureReference])
  @@index([activePaymentId])
}

model PreorderItem {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  qty Int @default(1)

  productSkuSnapshot  String?
  productNameSnapshot String?

  prixCatalogueFcfa Int
  discountPercent   Decimal @default(0.00) @db.Decimal(5, 2)
  prixUnitaireFcfa  Int

  ccUnitaire      Decimal @db.Decimal(10, 3)
  poidsUnitaireKg Decimal @db.Decimal(10, 3)

  lineTotalFcfa  Int
  lineTotalCc    Decimal @db.Decimal(12, 3)
  lineTotalPoids Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([preorderId, productId])
  @@index([productId])
}

model PreorderLog {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  action PreorderLogAction
  note   String?           @db.Text
  meta   Json?

  actorAdminId String?
  actorAdmin   AdminUser? @relation(fields: [actorAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([preorderId, createdAt])
  @@index([actorAdminId])
}

model StockMovement {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  preorderId String?
  preorder   Preorder? @relation(fields: [preorderId], references: [id], onDelete: SetNull)

  type   StockMovementType
  reason StockMovementReason

  qty Int

  note String? @db.Text
  meta Json?

  createdById    String?
  createdByAdmin AdminUser? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([preorderId])
  @@index([reason, createdAt])
  @@index([createdById])
}

//
// -----------------------------------------------------------------------------
// PAIEMENTS
// -----------------------------------------------------------------------------
//

model Payment {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation("PreorderPayments", fields: [preorderId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  provider   PaymentProvider
  methodType PaymentMethodType
  status     PaymentStatus     @default(INITIATED)

  amountExpectedFcfa Int
  amountPaidFcfa     Int    @default(0)
  currencyCode       String @default("XOF") @db.VarChar(3)

  providerAccountId String?
  providerAccount   PaymentProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)

  lastAttemptId String?

  providerReference String?
  providerTxnId     String?
  clientReference   String?

  initiatedAt DateTime  @default(now())
  paidAt      DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  expiredAt   DateTime?
  refundedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts           PaymentAttempt[]
  refunds            PaymentRefund[]
  transactionLogs    PaymentTransactionLog[]
  activeForPreorders Preorder[]       @relation("ActivePayment")

  @@unique([provider, providerTxnId])
  @@unique([provider, clientReference])
  @@index([preorderId])
  @@index([countryId, provider, status])
  @@index([providerAccountId])
  @@index([lastAttemptId])
}

model PaymentAttempt {
  id String @id @default(cuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  status   PaymentAttemptStatus @default(CREATED)

  providerSessionId     String?
  providerTransactionId String?
  providerPayerPhone    String?
  providerStatusLabel   String?

  checkoutUrl       String?
  deepLink          String?
  providerLaunchUrl String?
  qrPayload         String?

  requestPayloadJson    Json?
  responsePayloadJson   Json?
  normalizedPayloadJson Json?

  failureCode    String?
  failureMessage String? @db.Text

  expiresAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionLogs PaymentTransactionLog[]

  @@unique([provider, providerTransactionId])
  @@index([paymentId, createdAt])
  @@index([provider, providerSessionId])
}

model PaymentProviderAccount {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  label    String
  status   ProviderAccountStatus @default(ACTIVE)

  merchantIdentifier String?
  apiBaseUrl         String? @default("https://api.wave.com")
  configEncrypted    String  @db.Text

  supportsCheckout Boolean @default(true)
  supportsWebhook  Boolean @default(true)
  supportsRefund   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
  rules    PaymentProviderRule[]

  @@index([countryId, provider, status])
}

model PaymentProviderRule {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  methodType PaymentMethodType
  provider   PaymentProvider

  providerAccountId String?
  providerAccount   PaymentProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)

  priority  Int     @default(100)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId, methodType, isActive, priority])
  @@index([providerAccountId])
}

model PaymentWebhookEvent {
  id String @id @default(cuid())

  provider        PaymentProvider
  providerEventId String?
  eventType       String?

  signatureValid   Boolean                 @default(false)
  processingStatus WebhookProcessingStatus @default(RECEIVED)

  requestHeadersJson Json?
  payloadJson        Json
  errorMessage       String? @db.Text

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@unique([provider, providerEventId])
  @@index([provider, processingStatus, receivedAt])
}

model PaymentTransactionLog {
  id String @id @default(cuid())

  preorderId String?
  preorder   Preorder? @relation(fields: [preorderId], references: [id], onDelete: SetNull)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  paymentAttemptId String?
  paymentAttempt   PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)

  provider PaymentProvider?

  eventType PaymentTransactionEventType
  source    PaymentTransactionSource

  status       PaymentStatus?
  attemptStatus PaymentAttemptStatus?
  providerStatus String?

  providerSessionId     String?
  providerTransactionId String?
  providerPayerPhone    String?

  amountFcfa    Int?
  currencyCode  String? @db.VarChar(3)

  note       String? @db.Text
  payloadJson Json?

  actorAdminId String?
  actorAdmin   AdminUser? @relation(fields: [actorAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([preorderId, createdAt])
  @@index([paymentId, createdAt])
  @@index([paymentAttemptId, createdAt])
  @@index([provider, providerSessionId])
  @@index([provider, providerTransactionId])
  @@index([eventType, source, createdAt])
  @@index([actorAdminId])
}

model PaymentRefund {
  id String @id @default(cuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  provider PaymentProvider

  amountFcfa        Int
  currencyCode      String  @default("XOF") @db.VarChar(3)
  providerRefundRef String?

  status PaymentStatus @default(PROCESSING)
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
}
