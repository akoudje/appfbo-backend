// prisma/schema.prisma
// MVP Précommande FOREVER — React + Express + Postgres + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//
enum Grade {
  ANIMATEUR_ADJOINT
  ANIMATEUR
  MANAGER_ADJOINT
  MANAGER
  CLIENT_PRIVILEGIE
}

enum DeliveryMode {
  RETRAIT_SITE_FLP
  LIVRAISON
}

enum PaymentMode {
  WAVE
  ORANGE_MONEY
  ESPECES
  OTHER
}

enum PreorderStatus {
  DRAFT
  SUBMITTED
  INVOICED
  PAYMENT_PROOF_RECEIVED
  PAID
  READY
  FULFILLED
  CANCELLED
}

enum ProductCategory {
  NON_CLASSE
  BUVABLE
  COMBO_PACKS
  GESTION_DE_POIDS
  NUTRITION
  PRODUIT_DE_LA_RUCHE
  SOINS_DE_LA_PEAU
  SOINS_PERSONNELS
}

enum AdminRole {
  SUPER_ADMIN
  TECH_ADMIN
  OPERATIONS_DIRECTOR
  SALES_DIRECTOR
  BILLING_MANAGER
  MARKETING_ASSISTANT
  STOCK_MANAGER
  COUNTER_MANAGER
  INVOICER
  ORDER_PREPARER
}

//
// MODELS
//

model Fbo {
  id           String @id @default(cuid())
  numeroFbo    String @unique
  nomComplet   String
  grade        Grade
  pointDeVente String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorders Preorder[]
  fboCountries FboCountry[]

  @@index([pointDeVente])
  @@index([grade])
}

model Country {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  currencyCode String?
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings       CountrySettings?
  products       Product[]
  preorders      Preorder[]
  gradeDiscounts GradeDiscount[]
  adminUsers     AdminUser[]
  fboCountries   FboCountry[]
}

model CountrySettings {
  id          String   @id @default(cuid())
  countryId   String   @unique
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  minCartFcfa Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  fullName String?
  role     AdminRole
  actif    Boolean   @default(true)

  countryId String?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  invoicedPreorders        Preorder[] @relation("PreorderInvoicedBy")
  proofReceivedPreorders   Preorder[] @relation("PreorderProofReceivedBy")
  paymentVerifiedPreorders Preorder[] @relation("PreorderPaymentVerifiedBy")
  preparedPreorders        Preorder[] @relation("PreorderPreparedBy")
  fulfilledPreorders       Preorder[] @relation("PreorderFulfilledBy")
  cancelledPreorders       Preorder[] @relation("PreorderCancelledBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([role])
}

model FboCountry {
  id String @id @default(cuid())

  fboId   String
  fbo     Fbo    @relation(fields: [fboId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  pointDeVente String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([fboId, countryId])
  @@index([countryId])
}

model Product {
  id       String  @id @default(cuid())
  sku      String  @unique
  nom      String
  imageUrl String?
  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  category ProductCategory @default(NON_CLASSE)
  details  String?         @db.Text
  stockQty Int             @default(0)

  prixBaseFcfa Int
  cc           Decimal @db.Decimal(10, 3)
  poidsKg      Decimal @db.Decimal(10, 3)

  actif Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorderItems PreorderItem[]

  @@index([actif])
  @@index([nom])
  @@index([category])
  @@index([countryId])
}

model GradeDiscount {
  id        String  @id @default(cuid())
  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  grade     Grade

  // Remise en % (5 à 48). Exemple: 12.5
  discountPercent Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, grade])
  @@index([countryId])
}

model Preorder {
  id     String         @id @default(cuid())
  status PreorderStatus @default(DRAFT)
  countryId String
  country   Country      @relation(fields: [countryId], references: [id], onDelete: Restrict)

  // Liens & infos FBO au moment de la précommande
  fboId String
  fbo   Fbo    @relation(fields: [fboId], references: [id], onDelete: Restrict)

  // On fige certaines infos dans la précommande (même si FBO change après)
  fboNumero     String
  fboNomComplet String
  fboGrade      Grade
  pointDeVente  String

  paymentMode  PaymentMode
  deliveryMode DeliveryMode

  // Totaux figés (calculés lors du submit)
  totalCc            Decimal @default(0.000) @db.Decimal(12, 3)
  totalPoidsKg       Decimal @default(0.000) @db.Decimal(12, 3)
  totalProduitsFcfa  Int     @default(0)
  fraisLivraisonFcfa Int     @default(0)
  totalFcfa          Int     @default(0)

  // Message WhatsApp généré à l’étape 3
  whatsappMessage String?

  // Pour tracer la facturation
  factureReference  String?
  factureWhatsappTo String? // ex: "+221...." si tu veux garder le numéro choisi

  // ---- Traitement admin (facturier / préparateur) ----

  // Lien de paiement envoyé au FBO (Wave/OM/autre)
  paymentLink String?

  // Preuve de paiement (URL, ou texte si tu ne gères pas upload maintenant)
  paymentProofUrl  String?
  paymentRef       String?
  paymentProofNote String? @db.Text

  // Notes internes (support / préparation)
  internalNote String? @db.Text

  // Timestamps traitement
  invoicedAt      DateTime?
  proofReceivedAt DateTime?
  preparedAt      DateTime?
  fulfilledAt     DateTime?
  cancelledAt     DateTime?

  // Traces "par qui" (si pas encore de table User admin, on stocke un label)
  invoicedBy        String?
  proofReceivedBy   String?
  paymentVerifiedBy String?
  preparedBy        String?
  fulfilledBy       String?
  cancelledBy       String?

  invoicedById        String?
  proofReceivedById   String?
  paymentVerifiedById String?
  preparedById        String?
  fulfilledById       String?
  cancelledById       String?

  invoicedByAdmin        AdminUser? @relation("PreorderInvoicedBy", fields: [invoicedById], references: [id], onDelete: SetNull)
  proofReceivedByAdmin   AdminUser? @relation("PreorderProofReceivedBy", fields: [proofReceivedById], references: [id], onDelete: SetNull)
  paymentVerifiedByAdmin AdminUser? @relation("PreorderPaymentVerifiedBy", fields: [paymentVerifiedById], references: [id], onDelete: SetNull)
  preparedByAdmin        AdminUser? @relation("PreorderPreparedBy", fields: [preparedById], references: [id], onDelete: SetNull)
  fulfilledByAdmin       AdminUser? @relation("PreorderFulfilledBy", fields: [fulfilledById], references: [id], onDelete: SetNull)
  cancelledByAdmin       AdminUser? @relation("PreorderCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  // Livraison / retrait (optionnel)
  deliveryTracking String?
  packingNote      String? @db.Text
  cancelReason     String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?
  paidAt      DateTime?

  items PreorderItem[]
  logs  PreorderLog[]

  @@index([status, createdAt])
  @@index([countryId, status, createdAt])
  @@index([fboId])
  @@index([pointDeVente])
  @@index([invoicedById])
  @@index([proofReceivedById])
  @@index([paymentVerifiedById])
  @@index([preparedById])
  @@index([fulfilledById])
  @@index([cancelledById])
}

model PreorderItem {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  qty Int @default(1)

  // On fige les valeurs unitaires au moment du submit (important pour la facturation)
  prixUnitaireFcfa Int
  ccUnitaire       Decimal @db.Decimal(10, 3)
  poidsUnitaireKg  Decimal @db.Decimal(10, 3)

  lineTotalFcfa  Int
  lineTotalCc    Decimal @db.Decimal(12, 3)
  lineTotalPoids Decimal @db.Decimal(12, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([preorderId, productId])
  @@index([productId])
}

model PreorderLog {
  id         String   @id @default(cuid())
  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  action String
  note   String? @db.Text
  meta   Json?

  createdAt DateTime @default(now())

  @@index([preorderId, createdAt])
}
