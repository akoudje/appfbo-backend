// prisma/schema.prisma
// APP Précommande FOREVER — version révisée
// Cible: React + Express + Postgres + Prisma
// Inclut:
// - moteur de paiement multi-provider
// - répartition/assignation des précommandes aux facturiers
// - workflow commande modernisé

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
//

enum OrderMessageChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum OrderMessagePurpose {
  INVOICE
  PAYMENT_LINK
  REMINDER
  PAYMENT_CONFIRMED
  PREPARATION_STARTED
  ORDER_READY
  ORDER_FULFILLED
}

enum OrderMessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum Grade {
  ANIMATEUR_ADJOINT
  ANIMATEUR
  MANAGER_ADJOINT
  MANAGER
  CLIENT_PRIVILEGIE
}

enum DeliveryMode {
  RETRAIT_SITE_FLP
  LIVRAISON
}

enum PaymentProvider {
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  MOOV_MONEY
  MANUAL
}

enum PaymentMethodType {
  MOBILE_MONEY
  CASH
  BANK_TRANSFER
  CARD
  MANUAL_PROOF
}

enum PreorderPaymentMode {
  ESPECES
  WAVE
  ORANGE_MONEY
  BANK_TRANSFER
  ECOBANK_PAY
  PI_SPI
}

enum PaymentStatus {
  INITIATED
  PENDING_CUSTOMER_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ExternalPaymentLinkStatus {
  DRAFT
  ACTIVE
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentAttemptStatus {
  CREATED
  PROVIDER_SESSION_CREATED
  REDIRECT_READY
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAYMENT_PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
}

enum CashClosureStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum BankPaymentStatus {
  NOT_REQUIRED
  WAITING_PROOF
  PROOF_SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum BankPaymentProofStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum ProviderAccountStatus {
  ACTIVE
  INACTIVE
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum PaymentTransactionEventType {
  PAYMENT_INITIATED
  PROVIDER_SESSION_CREATED
  CHECKOUT_LINK_READY
  STATUS_SYNCED
  WEBHOOK_RECEIVED
  WEBHOOK_INVALID_SIGNATURE
  WEBHOOK_PROCESSED
  WEBHOOK_PREORDER_UNRESOLVED
  TRANSACTION_CAPTURED
  PAYER_PHONE_CAPTURED
  PAYMENT_CONFIRMED
  PAYMENT_EXPIRED
  PAYMENT_CANCELLED
  PAYMENT_FAILED
  DETAILS_ENRICHED
  SIMULATION_TRIGGERED
  SIMULATION_RESULT_APPLIED
}

enum PaymentTransactionSource {
  INITIATE
  SYNC
  WEBHOOK
  SIMULATION
  ENRICHMENT
  SYSTEM
}

enum PreorderStatus {
  DRAFT
  SUBMITTED
  INVOICED
  PAYMENT_PENDING
  PAID
  READY
  FULFILLED
  CANCELLED
}

enum BillingWorkStatus {
  NONE
  QUEUED
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER_DATA
  WAITING_PAYMENT
  COMPLETED
  RELEASED
  ESCALATED
}

enum BillingPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketEventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum TicketOrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
}

enum TicketStatus {
  RESERVED
  ACTIVE
  USED
  CANCELLED
}

enum ProductCategory {
  NON_CLASSE
  BUVABLE
  COMBO_PACKS
  GESTION_DE_POIDS
  NUTRITION
  PRODUIT_DE_LA_RUCHE
  SOINS_DE_LA_PEAU
  SOINS_PERSONNELS
}

enum AdminRole {
  SUPER_ADMIN
  TECH_ADMIN
  OPERATIONS_DIRECTOR
  SALES_DIRECTOR
  BILLING_MANAGER
  MARKETING_MANAGER
  MARKETING_ASSISTANT
  STOCK_MANAGER
  COUNTER_MANAGER
  CAISSIERE
  INVOICER
  ORDER_PREPARER
}

enum PreorderLogAction {
  CREATE_DRAFT
  SET_ITEMS
  REPRICE
  SUBMIT

  ENQUEUE_BILLING
  ASSIGN_INVOICER
  RELEASE_INVOICER
  START_BILLING
  ESCALATE_BILLING
  WAIT_CUSTOMER_DATA

  INVOICE
  GENERATE_PAYMENT
  PAYMENT_PENDING
  RECEIVE_MANUAL_PAYMENT_PROOF
  VALIDATE_MANUAL_PAYMENT
  PAYMENT_CONFIRMED

  LAUNCH_PREPARATION
  PREPARE
  FULFILL
  CANCEL

  STOCK_DEBIT
  STOCK_CREDIT
}

enum StockMovementType {
  DEBIT
  CREDIT
}

enum StockMovementReason {
  PREPARE_ORDER
  CANCEL_ORDER
  MANUAL_ADJUSTMENT
}

//
// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------
//

model OrderMessage {
  id String @id @default(cuid())

  preorderId String
  preorder   Preorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  channel OrderMessageChannel @default(WHATSAPP)
  purpose OrderMessagePurpose
  status  OrderMessageStatus  @default(DRAFT)

  toPhone String?
  body    String? @db.Text

  provider          String?
  providerMessageId String? @unique

  paymentLinkTracked String? @db.Text
  paymentLinkTarget  String? @db.Text

  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  lastStatusAt DateTime?

  errorCode    String?
  errorMessage String? @db.Text

  attempts          Int       @default(0)
  maxAttempts       Int       @default(4)
  nextAttemptAt     DateTime?
  lastAttemptAt     DateTime?
  processingStartedAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events OrderMessageEvent[]

  @@index([preorderId, createdAt])
  @@index([status])
  @@index([channel, status, nextAttemptAt])
  @@index([provider, providerMessageId])
}

model OrderMessageEvent {
  id String @id @default(cuid())

  orderMessageId String
  orderMessage   OrderMessage @relation(fields: [orderMessageId], references: [id], onDelete: Cascade)

  status     String
  rawPayload Json?
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([orderMessageId, createdAt])
}

model Fbo {
  id           String @id @default(cuid())
  numeroFbo    String @unique
  nomComplet   String
  email        String?
  grade        Grade
  pointDeVente String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorders    Preorder[]
  fboCountries FboCountry[]
  customerOtpChallenges CustomerOtpChallenge[]
  bankPaymentProofs BankPaymentProof[]
  mobilePushTokens MobilePushToken[]
  customerNotificationReads CustomerNotificationRead[]

  @@index([pointDeVente])
  @@index([grade])
}

model Country {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  currencyCode String?
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings                CountrySettings?
  marketingContent        CountryMarketingContent?
  products                Product[]
  countryProducts         CountryProduct[]
  gradePrices             ProductGradePrice[]
  preorders               Preorder[]
  gradeDiscounts          GradeDiscount[]
  adminUsers              AdminUser[]
  fboCountries            FboCountry[]
  payments                Payment[]
  paymentProviderAccounts PaymentProviderAccount[]
  paymentProviderRules    PaymentProviderRule[]
  cashClosures            CashClosure[]
  customerOtpChallenges   CustomerOtpChallenge[]
  bankPaymentProofs       BankPaymentProof[]
  stockMovements          StockMovement[]
  paymentLinkResendRequests PaymentLinkResendRequest[]
  pickupCodeResendRequests PickupCodeResendRequest[]
  mobilePushTokens MobilePushToken[]
  ticketEvents TicketEvent[]
  ticketOrders TicketOrder[]
  tickets Ticket[]
  externalPaymentLinks ExternalPaymentLink[]
}

model MobilePushToken {
  id String @id @default(cuid())

  token String @unique
  platform String?
  enabled Boolean @default(true)

  fboId String?
  fbo Fbo? @relation(fields: [fboId], references: [id], onDelete: Cascade)

  countryId String?
  country Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)

  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fboId, enabled])
  @@index([countryId, enabled])
  @@index([platform])
  @@index([lastSeenAt])
}

model CountrySettings {
  id        String  @id @default(cuid())
  countryId String  @unique
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  minCartFcfa Int @default(0)
  maxQtyPerProduct Int @default(10)
  preorderSubmissionEnabled Boolean @default(true)
  preorderSubmissionDisabledMessage String? @db.Text
  publicAnnouncementEnabled Boolean @default(false)
  publicAnnouncementMessage String? @db.Text
  closedOnSaturday Boolean @default(false)
  supportPhone String?
  pickupAddress String? @db.Text
  defaultPointDeVente String?
  enableWave Boolean @default(true)
  enableOrangeMoney Boolean @default(true)
  enableCash Boolean @default(true)
  enableBankTransfer Boolean @default(true)
  enableEcobankPay Boolean @default(false)
  ecobankPayMerchantName String?
  ecobankPayMerchantId String?
  ecobankPayTerminalName String?
  ecobankPayTerminalId String?
  ecobankPayQrImageUrl String?
  ecobankPayInstructions String? @db.Text
  enablePiSpi Boolean @default(false)
  piSpiAlias String?
  piSpiMerchantName String?
  piSpiQrImageUrl String?
  piSpiInstructions String? @db.Text
  enableDelivery Boolean @default(true)
  enablePickup Boolean @default(true)
  bankAccountLabel String?
  bankName String?
  bankAccountNumber String?
  bankIban String?
  bankSwift String?
  bankAccountHolder String?
  bankPaymentDueHours Int @default(72)
  bankProofMaxFileSizeMb Int @default(8)
  currencyLabel String? @default("FCFA")
  pricingDisclaimer String? @db.Text
  themePrimaryColor String?
  themeSecondaryColor String?
  themeDarkColor String?
  themeLogoPath String?
  themeSliderEnabled Boolean @default(true)
  themeSidePanelsEnabled Boolean @default(true)
  notificationTemplates Json?
  fboHelpTopics Json?

  // Paramètres opérationnels facturation
  maxActiveBillingPerInvoicer Int @default(10)
  billingClaimTimeoutMin      Int @default(30)
  preinvoicedAutoCancelAfterHours Int @default(2)
  preinvoicedAutoReminderAfterHours Int @default(1)
  preinvoicedAutoCancelAfterMinutes Int @default(120)
  preinvoicedAutoReminderAfterMinutes Int @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CountryMarketingContent {
  id String @id @default(cuid())

  countryId String @unique
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  slidesJson Json?
  sidePanelsJson Json?
  publishingJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  fullName String?
  role     AdminRole
  actif    Boolean   @default(true)
  lastLoginAt DateTime?
  passwordChangedAt DateTime?
  failedLoginCount Int @default(0)
  lockedUntil DateTime?
  permissionAllow Json?
  permissionDeny Json?

  countryId String?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  // Précommandes / workflow
  assignedBillingPreorders        Preorder[] @relation("PreorderAssignedInvoicer")
  invoicedPreorders               Preorder[] @relation("PreorderInvoicedBy")
  manualPaymentValidatedPreorders Preorder[] @relation("PreorderManualPaymentValidatedBy")
  bankPaymentValidatedPreorders   Preorder[] @relation("PreorderBankPaymentValidatedBy")
  launchedPreparationPreorders    Preorder[] @relation("PreorderPreparationLaunchedBy")
  pickupCodeVerifiedPreorders     Preorder[] @relation("PreorderPickupCodeVerifiedBy")
  preparedPreorders               Preorder[] @relation("PreorderPreparedBy")
  fulfilledPreorders              Preorder[] @relation("PreorderFulfilledBy")
  cancelledPreorders              Preorder[] @relation("PreorderCancelledBy")

  stockMovements StockMovement[]
  preorderLogs   PreorderLog[]
  paymentTransactionLogs PaymentTransactionLog[]
  reviewedBankPaymentProofs BankPaymentProof[]
  cashierTransactions CashierTransaction[] @relation("CashierTransactionCashier")
  cashClosuresAsCashier CashClosure[] @relation("CashClosureCashier")
  cashClosuresSubmitted CashClosure[] @relation("CashClosureSubmittedBy")
  cashClosuresReviewed CashClosure[] @relation("CashClosureReviewedBy")
  checkedPreparationItems PreparationChecklistItem[]
  createdPreparationAnomalies PreparationAnomaly[] @relation("PreparationAnomalyCreatedBy")
  resolvedPreparationAnomalies PreparationAnomaly[] @relation("PreparationAnomalyResolvedBy")
  createdTicketEvents TicketEvent[] @relation("TicketEventCreatedBy")
  updatedTicketEvents TicketEvent[] @relation("TicketEventUpdatedBy")
  checkedInTickets Ticket[] @relation("TicketCheckedInBy")
  createdExternalPaymentLinks ExternalPaymentLink[] @relation("ExternalPaymentLinkCreatedBy")
  updatedExternalPaymentLinks ExternalPaymentLink[] @relation("ExternalPaymentLinkUpdatedBy")
  auditLogsAuthored AdminUserAuditLog[] @relation("AdminUserAuditActor")
  auditLogsTargeted AdminUserAuditLog[] @relation("AdminUserAuditTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([role])
  @@index([lockedUntil])
}

model AdminUserAuditLog {
  id String @id @default(cuid())

  actorAdminId String?
  actorAdmin   AdminUser? @relation("AdminUserAuditActor", fields: [actorAdminId], references: [id], onDelete: SetNull)

  targetAdminId String?
  targetAdmin   AdminUser? @relation("AdminUserAuditTarget", fields: [targetAdminId], references: [id], onDelete: SetNull)

  action String
  note   String? @db.Text
  meta   Json?

  createdAt DateTime @default(now())

  @@index([actorAdminId, createdAt])
  @@index([targetAdminId, createdAt])
  @@index([action, createdAt])
}

model FboCountry {
  id String @id @default(cuid())

  fboId String
  fbo   Fbo    @relation(fields: [fboId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  pointDeVente String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([fboId, countryId])
  @@index([countryId])
}

model Product {
  id       String  @id @default(cuid())
  sku      String  @unique
  nom      String
  imageUrl String?

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  category ProductCategory @default(NON_CLASSE)
  details  String?         @db.Text
  stockQty Int             @default(0)
  maxQtyPerOrder Int?
  gradePrices ProductGradePrice[]

  prixBaseFcfa Int
  cc           Decimal @db.Decimal(10, 3)
  poidsKg      Decimal @db.Decimal(10, 3)

  actif Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preorderItems  PreorderItem[]
  stockMovements StockMovement[]
  countryProducts CountryProduct[]

  @@index([actif])
  @@index([nom])
  @@index([category])
  @@index([countryId])
}

model CountryProduct {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  prixBaseFcfa Int
  stockQty Int @default(0)
  actif Boolean @default(true)
  maxQtyPerOrder Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, productId])
  @@index([productId])
  @@index([countryId])
  @@index([actif])
}

model ProductGradePrice {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  grade Grade
  prixFcfa Decimal @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, productId, grade])
  @@index([productId])
  @@index([countryId])
}

model GradeDiscount {
  id String @id @default(cuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  grade Grade

  discountPercent Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, grade])
  @@index([countryId])
}

model Preorder {
  id String @id @default(cuid())

  // Numéro de precommande 
  preorderNumber  String? @unique
  preorderSeq     Int?
  preorderDateKey String?

  // mode de paiement
  preorderPaymentMode PreorderPaymentMode?

  // Workflow global commande
  status        PreorderStatus     @default(DRAFT)
  paymentStatus OrderPaymentStatus @default(UNPAID)

  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  fboId String
  fbo   Fbo    @relation(fields: [fboId], references: [id], onDelete: Restrict)

  // Snapshot FBO
  fboNumero     String
  fboNomComplet String
  fboEmail      String?
  fboGrade      Grade
  billingGrade  Grade?
  pointDeVente  String

  // FBO qui a passé la commande lorsqu'il agit pour un autre FBO.
  placedByFboNumero      String?
  placedByFboName        String?
  placedByFboPhone       String?
  placedByFboEmail       String?
  placedByHomeCountryCode String?

  // Livraison
  deliveryMode DeliveryMode?

  // Protection des données personnelles
  personalDataConsentAccepted  Boolean   @default(false)
  personalDataConsentAcceptedAt DateTime?
  personalDataConsentVersion   String?

  // Totaux
  totalCc            Decimal @default(0.000) @db.Decimal(12, 3)
  totalPoidsKg       Decimal @default(0.000) @db.Decimal(12, 3)
  totalProduitsFcfa  Int     @default(0)
  fraisLivraisonFcfa Int     @default(0)
  totalFcfa          Int     @default(0)
  indicativeTotalFcfa Int?
  computedGradeTotalFcfa Int?
  as400InvoiceTotalFcfa Int?

  // File / répartition facturiers
  billingWorkStatus     BillingWorkStatus @default(NONE)
  billingPriority       BillingPriority   @default(NORMAL)
  billingQueueEnteredAt DateTime?
  assignedAt            DateTime?
  billingStartedAt      DateTime?
  billingLastActivityAt DateTime?
  billingCompletedAt    DateTime?
  billingReleasedAt     DateTime?
  billingEscalatedAt    DateTime?
  billingSlaDeadlineAt  DateTime?

  assignedInvoicerId String?
  assignedInvoicer   AdminUser? @relation("PreorderAssignedInvoicer", fields: [assignedInvoicerId], references: [id], onDelete: SetNull)

  // Facturation
  factureReference  String?
  paymentCollectionCode String?
  factureWhatsappTo String?
  billingAdjustmentReason String? @db.Text
  parcelNumber      String? @unique
  invoicedAt        DateTime?
  paymentExpiresAt  DateTime?
  invoicedById      String?
  invoicedByAdmin   AdminUser? @relation("PreorderInvoicedBy", fields: [invoicedById], references: [id], onDelete: SetNull)

  // Paiement manuel (cas spécifique)
  manualPaymentReference     String?
  manualPaymentProofUrl      String?
  manualPaymentProofNote     String?    @db.Text
  manualPaymentReceivedAt    DateTime?
  manualPaymentValidatedAt   DateTime?
  manualPaymentValidatedById String?
  manualPaymentValidatedBy   AdminUser? @relation("PreorderManualPaymentValidatedBy", fields: [manualPaymentValidatedById], references: [id], onDelete: SetNull)

  // Paiement global
  paymentProvider PaymentProvider?
  paidAt          DateTime?
  bankPaymentStatus BankPaymentStatus @default(NOT_REQUIRED)
  bankPaymentDueAt DateTime?
  bankPaymentValidatedAt DateTime?
  bankPaymentValidatedById String?
  bankPaymentValidatedBy AdminUser? @relation("PreorderBankPaymentValidatedBy", fields: [bankPaymentValidatedById], references: [id], onDelete: SetNull)

  // Paiement actif (facilite les écrans)
  activePaymentId String?
  activePayment   Payment? @relation("ActivePayment", fields: [activePaymentId], references: [id], onDelete: SetNull)

  // Préparation / fulfillment
  preparationLaunchedAt DateTime?
  preparedAt  DateTime?
  fulfilledAt DateTime?
  cancelledAt DateTime?

  preparationLaunchedById String?
  pickupCodeVerifiedById  String?
  preparedById  String?
  fulfilledById String?
  cancelledById String?

  preparationLaunchedBy AdminUser? @relation("PreorderPreparationLaunchedBy", fields: [preparationLaunchedById], references: [id], onDelete: SetNull)
  pickupCodeVerifiedBy AdminUser? @relation("PreorderPickupCodeVerifiedBy", fields: [pickupCodeVerifiedById], references: [id], onDelete: SetNull)
  preparedByAdmin  AdminUser? @relation("PreorderPreparedBy", fields: [preparedById], references: [id], onDelete: SetNull)
  fulfilledByAdmin AdminUser? @relation("PreorderFulfilledBy", fields: [fulfilledById], references: [id], onDelete: SetNull)
  cancelledByAdmin AdminUser? @relation("PreorderCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  // Divers
  whatsappMessage       String?   @db.Text
  lastWhatsappMessageId String?
  lastWhatsappStatus    String?
  lastWhatsappStatusAt  DateTime?

  paymentLinkClickedAt  DateTime?
  paymentLinkClickCount Int       @default(0)

  internalNote String? @db.Text

  deliveryTracking String?
  fulfillmentMode String?
  pickupPointLabel String?
  deliveryCarrier String?
  packingNote      String? @db.Text
  pickupSecretCode String?
  pickupCodeVerifiedAt DateTime?
  pickupRecipientType String?
  pickupRecipientName String?
  pickupRecipientPhone String?
  pickupConfirmationNote String? @db.Text
  cancelReason     String? @db.Text

  stockDeductedAt DateTime?
  stockRestoredAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  items          PreorderItem[]
  logs           PreorderLog[]
  messages       OrderMessage[]
  payments       Payment[]       @relation("PreorderPayments")
  cashierTransactions CashierTransaction[]
  preparationItems PreparationChecklistItem[]
  preparationAnomalies PreparationAnomaly[]
  paymentTransactionLogs PaymentTransactionLog[]
  stockMovements StockMovement[]
  bankPaymentProofs BankPaymentProof[]
  paymentLinkResendRequests PaymentLinkResendRequest[]
  pickupCodeResendRequests PickupCodeResendRequest[]

  @@index([status, createdAt])
  @@index([preorderPaymentMode])
  @@index([countryId, status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([fboId])
  @@index([placedByFboNumero])
  @@index([pointDeVente])
  @@index([billingWorkStatus, billingPriority, billingQueueEnteredAt])
  @@index([assignedInvoicerId, billingWorkStatus])
  @@index([billingSlaDeadlineAt])
  @@index([invoicedById])
  @@index([manualPaymentValidatedById])
  @@index([preparationLaunchedById])
  @@index([preparationLaunchedAt])
  @@index([pickupCodeVerifiedById])
  @@index([preparedById])
  @@index([fulfilledById])
  @@index([cancelledById])
  @@index([factureReference])
  @@index([paymentExpiresAt])
  @@index([paymentCollectionCode])
  @@index([activePaymentId])
  @@index([bankPaymentStatus, bankPaymentDueAt])
  @@index([bankPaymentValidatedById])
}

model CustomerOtpChallenge {
  id String @id @default(cuid())

  countryId String
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  fboId String
  fbo Fbo @relation(fields: [fboId], references: [id], onDelete: Cascade)

  purpose String @default("CUSTOMER_PORTAL_LOGIN")
  channel String
  destinationMasked String?

  codeHash String
  expiresAt DateTime
  consumedAt DateTime?

  attempts Int @default(0)
  maxAttempts Int @default(5)

  meta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId, fboId, createdAt])
  @@index([fboId, consumedAt, expiresAt])
}

model CustomerNotificationRead {
  id String @id @default(cuid())

  fboId String
