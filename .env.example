PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/appfbo
NODE_ENV=development
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d
CUSTOMER_JWT_SECRET=replace_with_another_strong_random_secret
CUSTOMER_JWT_EXPIRES_H=12
CUSTOMER_OTP_EXPIRES_MIN=10
CUSTOMER_OTP_PEPPER=replace_with_strong_random_pepper

ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_TOKEN_URL=https://api.orange.com/oauth/v3/token
ORANGE_SENDER_ADDRESS=tel:+225894650
ORANGE_SENDER_NUMBER=894650

ORANGE_WEBHOOK_TOKEN=
BREVO_WEBHOOK_TOKEN=
WAVE_WEBHOOK_SECRET=
WAVE_WEBHOOK_SIGNATURE_HEADER=wave-signature

# Email SMTP (Brevo / SendGrid / SMTP classique)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FOREVER
EMAIL_BRAND_LOGO_URL=https://appfbo-frontend.vercel.app/logo-forever.png
EMAIL_SIMULATE=false
NOTIFICATION_DEDUP_WINDOW_SECONDS=60

# Sécurité (laisser à false en production)
ALLOW_HEADER_AUTH=false
ALLOW_QUERY_TOKEN_AUTH=false
ENABLE_SEED_SUPER_ADMIN=false

# CORS
# Liste d'origines front autorisées, séparées par des virgules
# Exemple:
# ALLOWED_ORIGINS=https://admin.forevercivstore.com,https://www.forevercivstore.com,https://forevercivstore.com
ALLOWED_ORIGINS=
# Patterns wildcard pour sous-domaines (syntaxe simple avec *)
# Exemple:
# ALLOWED_ORIGIN_PATTERNS=https://*.forevercivstore.com,https://*.vercel.app
ALLOWED_ORIGIN_PATTERNS=
